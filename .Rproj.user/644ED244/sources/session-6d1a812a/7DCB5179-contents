library("here")
source(here("R", "packages.R"))

# Load in dataset
leduc <- readRDS(here("data", "leduc.rds"))

sce_leduc <- getWithColData(leduc, "proteinSweep")
leduc_filtered <- sce_leduc[,sce_leduc$MelanomaSubCluster %in% "A" | sce_leduc$SampleType == "Monocyte"]

id_melA <- which(leduc_filtered$SampleType == "Melanoma")
id_mon <- which(leduc_filtered$SampleType == "Monocyte")

# construct 2 mock groups out of the Monocytes
set.seed(1234)
idX <- sample(id_mon, size = length(id_mon)/2)
idY <- setdiff(id_mon, idX)

# add some of the Melanoma A cells to group Y to introduce signal
set.seed(123456)
id_spikein <- sample(id_melA, size = length(id_melA)*0.1)

leduc_filtered$group <- NA
leduc_filtered$group[idX] <- "X"
leduc_filtered$group[idY] <- "Y"
leduc_filtered$group[id_spikein] <- "Y"
names_spikein <- colnames(leduc_filtered)[id_spikein]

leduc_case <- leduc_filtered[,which(!is.na(leduc_filtered$group))]

leduc_case_mock_temp <- leduc_filtered[,-id_spikein]
leduc_case_mock <- leduc_case_mock_temp[,which(!is.na(leduc_case_mock_temp$group))]

# DD analysis
leduc_case_gamdid <- compDistr(object = leduc_case, covariate = "group", minObs = 50)

### Mock analysis
leduc_case_mock_gamdid <- compDistr(object = leduc_case_mock, covariate = "group", minObs = 50)

# DE analysis
keeprows <- apply(assay(leduc_case), 1, function(x) all(tapply(!is.na(x), colData(leduc_case)[["group"]], sum) > 50))

leduc_case_msqrob <- msqrob(leduc_case[keeprows,],
                            formula= ~ group, modelColumnName = "msqrobModel")
L <- makeContrast("groupY = 0",
                  parameterNames = names(getCoef(rowData(leduc_case_msqrob)$msqrobModel[[7]])))
leduc_case_msqrob <- hypothesisTest(leduc_case_msqrob, contrast = L,
                                    modelColumn = "msqrobModel", overwrite=TRUE)

saveRDS(object = leduc_case_gamdid, here("caseStudy_results", "leduc_case_gamdid"))
saveRDS(object = leduc_case_mock_gamdid, here("caseStudy_results", "leduc_case_mock_gamdid"))
saveRDS(object = leduc_case_msqrob, here("caseStudy_results", "leduc_case_msqrob"))
saveRDS(object = names_spikein, here("caseStudy_results", "names_spikein"))


# generate p values of the features only picked up msqrob2

DA_features <- rowData(leduc_case_msqrob)$groupY %>%
  filter(adjPval < 0.05) %>%
  rownames_to_column() %>%
  pull(rowname)
DD_features <- as.data.frame(rowData(leduc_case_gamdid)) %>%
  filter(groupX_VS_groupY < 0.05) %>%
  rownames_to_column() %>%
  pull(rowname)

rowData(leduc_case_msqrob)$groupY[setdiff(DA_features, DD_features),]
rowData(leduc_case_gamdid)[setdiff(DA_features, DD_features),"groupX_VS_groupY"]

rowData(leduc_case_msqrob)$groupY[setdiff(DD_features, DA_features),]
rowData(leduc_case_gamdid)[setdiff(DD_features, DA_features),"groupX_VS_groupY"]


