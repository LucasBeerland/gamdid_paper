# DE (Different expression  mean shift) => mean shift = distinct beter

```{r}
features <- 1000
sampleSize <- 100
DE_0.8diff_assay <- DE_0.7diff_assay <- DE_0.6diff_assay <- DE_0.5diff_assay <- DE_0.4diff_assay <- 
  matrix(NA, nrow = features, ncol = 2*sampleSize)
coldata <- data.frame(SampleType = rep(c("A","B"), each = sampleSize))
set.seed(100)
sign_groups <- sample(features, round(0.2*features))
tp <- 1:features %in% sign_groups
for (i in 1:features){
  set.seed(i)
  A <- rnorm(n = sampleSize, mean = 5, sd = 1)
  if (i %in% sign_groups){
    B0.8 <- rnorm(n = sampleSize, mean = 5.8, sd = 1)
    B0.7 <- rnorm(n = sampleSize, mean = 5.7, sd = 1)
    B0.6 <- rnorm(n = sampleSize, mean = 5.6, sd = 1)
    B0.5 <- rnorm(n = sampleSize, mean = 5.5, sd = 1)
    B0.4 <- rnorm(n = sampleSize, mean = 5.4, sd = 1)
  } else {
    B0.8 <- B0.7 <- B0.6 <- B0.5 <- B0.4 <-rnorm(n = sampleSize, mean = 5, sd = 1)
  }
  DE_0.8diff_assay[i,] <- c(A,B0.8)
  DE_0.7diff_assay[i,] <- c(A,B0.7)
  DE_0.6diff_assay[i,] <- c(A,B0.6)
  DE_0.5diff_assay[i,] <- c(A,B0.5)
  DE_0.4diff_assay[i,] <- c(A,B0.4)
}
sce_DE_0.8diff <- SingleCellExperiment(assays = DE_0.8diff_assay, colData = coldata)
sce_DE_0.7diff <- SingleCellExperiment(assays = DE_0.7diff_assay, colData = coldata)
sce_DE_0.6diff <- SingleCellExperiment(assays = DE_0.6diff_assay, colData = coldata)
sce_DE_0.5diff <- SingleCellExperiment(assays = DE_0.5diff_assay, colData = coldata)
sce_DE_0.4diff <- SingleCellExperiment(assays = DE_0.4diff_assay, colData = coldata)

rownames(sce_DE_0.8diff) <- rownames(sce_DE_0.7diff) <- rownames(sce_DE_0.6diff) <- 
  rownames(sce_DE_0.5diff) <- rownames(sce_DE_0.4diff) <- 1:features

DE_0.8diff_fdp <- makeFdpCurve(sce_mock = sce_DE_0.8diff, idA = 1:100, idB = 101:200, 
                               mock = F, tp = tp, title = "DE (difference 0.8)")

DE_0.7diff_fdp <- makeFdpCurve(sce_mock = sce_DE_0.7diff, idA = 1:100, idB = 101:200, 
                               mock = F, tp = tp, title = "DE (difference 0.7)")

DE_0.6diff_fdp <- makeFdpCurve(sce_mock = sce_DE_0.6diff, idA = 1:100, idB = 101:200, 
                               mock = F, tp = tp, title = "DE (difference 0.6)")

DE_0.5diff_fdp <- makeFdpCurve(sce_mock = sce_DE_0.5diff, idA = 1:100, idB = 101:200, 
                               mock = F, tp = tp, title = "DE (difference 0.5)")

DE_0.4diff_fdp <- makeFdpCurve(sce_mock = sce_DE_0.4diff, idA = 1:100, idB = 101:200, 
                               mock = F, tp = tp, title = "DE (difference 0.4)")
```

```{r}
DE_0.4diff_fdp$plot
DE_0.5diff_fdp$plot

DE_0.8diff_fdp$fdp$Diff <- 0.8
DE_0.7diff_fdp$fdp$Diff <- 0.7
DE_0.6diff_fdp$fdp$Diff <- 0.6
DE_0.5diff_fdp$fdp$Diff <- 0.5
