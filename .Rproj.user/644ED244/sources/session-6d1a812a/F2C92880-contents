## Examine the FDR control problem
```{r}
features <- 2000
sampleSize <- 100
DP_0.20diff_assay_test <- matrix(NA, nrow = features, ncol = 2*sampleSize)
coldata <- data.frame(SampleType = rep(c("A","B"), each = sampleSize))
set.seed(100)
sign_groups <- sample(features, round(0.2*features))
tp <- 1:features %in% sign_groups
for (i in 1:features){
  set.seed(i)
  A <- rbinorm(n = sampleSize, mean1 = 5, mean2 = 10, sd1 = 1, sd2 = 1, prop = 0.5)
  if (i %in% sign_groups){
    B0.20 <- rbinorm(n = sampleSize, mean1 = 5, mean2 = 10, sd1 = 1, sd2 = 1, prop = 0.8)
  } else {
    B0.20 <- rbinorm(n = sampleSize, mean1 = 5, mean2 = 10, sd1 = 1, sd2 = 1, prop = 0.5)
  }
  DP_0.20diff_assay_test[i,] <- c(A,B0.20)
}
sce_DP_0.20diff_test <- SingleCellExperiment(assays = DP_0.20diff_assay_test, colData = coldata)

rownames(sce_DP_0.20diff_test) <- 1:features

DP_0.20diff_fdp_test <- makeFdpCurve(sce_mock = sce_DP_0.20diff_test, idA = 1:100, idB = 101:200, 
                                 mock = F, tp = tp, title = "DP (difference 0.20) - test")
```
