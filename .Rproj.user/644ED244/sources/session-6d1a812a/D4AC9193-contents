      theme(plot.title = element_text(size = 15, face = "bold", hjust = 0.5))

# pvalH0 inflation at 1 -> fdr points become too conservative (fdr curves remain the same)
# pvalH0 inflation at 0 -> fdr points become too liberal (fdr curves become worse, especially for weaker alternative hypotheses)
