pvalHa_custom <- runif(n_Ha, 0, 0.009)

tp <- rep(c(F,T), c(n_H0, n_Ha))


rbind(tprFdp(pval = c(pvalH0_wrong, pvalHa_extraweak), tp = tp, adjPval = p.adjust(c(pvalH0_wrong, pvalHa_extraweak), method = "fdr")),
      tprFdp(pval = c(pvalH0_wrong, pvalHa_weak), tp = tp, adjPval = p.adjust(c(pvalH0_wrong, pvalHa_weak), method = "fdr")),
      tprFdp(pval = c(pvalH0_wrong, pvalHa_mid), tp = tp, adjPval = p.adjust(c(pvalH0_wrong, pvalHa_mid), method = "fdr")),
      tprFdp(pval = c(pvalH0_wrong, pvalHa_strong), tp = tp, adjPval = p.adjust(c(pvalH0_wrong, pvalHa_strong), method = "fdr")),
      tprFdp(pval = c(pvalH0_wrong, pvalHa_extrastrong), tp = tp, adjPval = p.adjust(c(pvalH0_wrong, pvalHa_extrastrong), method = "fdr")),
      tprFdp(pval = c(pvalH0_wrong, pvalHa_custom), tp = tp, adjPval = p.adjust(c(pvalH0_wrong, pvalHa_custom), method = "fdr"))) ->
  curve_data_wrong
curve_data_wrong$Hypothesis <- factor(rep(c("Extreme weak", "Weak", "Mid", "Strong", "Extreme strong", "Custom"), each = n_H0+n_Ha)) 

curve_data_wrong%>%
  group_by(Hypothesis) %>%
  dplyr::slice(which.min(abs(adjPval - 0.05))) -> curve_point_wrong

ggplot(curve_data_wrong) + 
      geom_point(aes(x = fdp, y = tpr, colour = Hypothesis), size = 0.01) +
      geom_point(data = curve_point_wrong, mapping = aes(x = fdp, y = tpr, colour = Hypothesis), size = 3) +
      geom_vline(xintercept = 0.05, lty = 2) +
