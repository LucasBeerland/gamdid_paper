library("gamdid")
# DD
leduc_gamdid <- compDistr(leduc, i = "proteinSweep", covariate = "SampleType")
rowData(leduc_gamdid)
rowData(leduc_gamdid[["proteinSweep"]])
rowData(leduc_gamdid[["proteinSweep"]])$"SampleTypeMelanoma_VS_SampleTypeMonocyte"
rowData(leduc_gamdid[["proteinSweep"]])
p_de <- rowData(leduc_msqrob[["proteinSweep"]])$SampleTypeMonocyte["Q9NX24",]
p_dd <- rowData(leduc_gamdid[["proteinSweep"]])$"SampleTypeMelanoma_VS_SampleTypeMonocyte"
cbind(p_de, p_dd)
cbind(p_de = p_de[adjPval], p_dd)
cbind(p_de = p_de["adjPval"], p_dd)
cbind(p_de = p_de$adjPval, p_dd)
rowanmes(p_de)
rownames(p_de)
p_de
p_de <- rowData(leduc_msqrob[["proteinSweep"]])$SampleTypeMonocyte["Q9NX24",]
p_de
rowData(leduc_msqrob[["proteinSweep"]])$SampleTypeMonocyte
p_de <- rowData(leduc_msqrob[["proteinSweep"]])$SampleTypeMonocyte
cbind(name = rownames(p_de),p_de = p_de$adjPval, p_dd)
data.frame(name = rownames(p_de), p_de = p_de$adjPval, p_dd)
data.frame(name = rownames(p_de), p_de = p_de$adjPval, p_dd) %>%
filter(p_de > 0.05 & p_dd < 0.05)
data.frame(name = rownames(p_de), p_de = p_de$adjPval, p_dd) %>%
filter(p_de > 0.05 & p_dd < 0.05) %>% pull(name) -> intersting
data.frame(name = rownames(p_de), p_de = p_de$adjPval, p_dd) %>%
filter(p_de > 0.05 & p_dd < 0.05) %>% pull(name) -> int
